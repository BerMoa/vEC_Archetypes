archetype (adl_version=1.4; uid=942ef0d2-e8ab-4a76-a8cc-db58e0d19130)
	openEHR-EHR-EVALUATION.epilepsy_family_history.v1

concept
	[at0000]

language
	original_language = <[ISO_639-1::de]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"vEC team">
			>
		>
	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Epilepsiespezifische Familienanamnese als Ergaenzung zu publizierten Family-History-Artefakten.">
			use = <"Zur strukturierten Erfassung epilepsiespezifischer Familienmuster, genetischer Hinweise und Konsanguinitaet inklusive Grad- oder Freitextangabe.">
			misuse = <"Nicht fuer die allgemeine Stammbaumanamnese oder nicht-epilepsiespezifische Familienerkrankungen verwenden; dafuer publizierte Family-History-Artefakte bevorzugen.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Epilepsy-specific family-history evaluation that complements published family-history artefacts.">
			use = <"Use for epilepsy-specific familial patterns, gene confirmation in relatives, and consanguinity context including degree or free-text detail.">
			misuse = <"Do not use for generic pedigree capture or non-epilepsy family conditions; prefer published family-history artefacts for that scope.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"72454071f464c5cddade35738877dd85">
		["build_uid"] = <"8dfa9625-5595-3f08-9a5c-74754ed2ff60">
	>

definition
	EVALUATION[at0000] matches {    -- Epilepsiespezifische Familienanamnese
		data matches {
			ITEM_TREE[at0001] matches {    -- Familiendaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Familienanamnese Epilepsie
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Familienanamnese Fieberkraempfe
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0012] occurrences matches {0..*} matches {    -- Betroffene Verwandte
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- Mutter
									at0101,    -- Vater
									at0102,    -- Geschwister
									at0103,    -- Grosseltern muetterlicherseits
									at0104,    -- Grosseltern vaeterlicherseits
									at0105,    -- Onkel oder Tanten muetterlicherseits
									at0106,    -- Onkel oder Tanten vaeterlicherseits
									at0107,    -- Halbgeschwister
									at0108]    -- Andere
								}
							}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Syndromname in der Familie
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Genetischer Befund in der Familie bestaetigt
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Genname in der Familie
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- Konsanguinitaet
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Pedigree dokumentiert
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Pedigree-Notiz
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0019] occurrences matches {0..1} matches {    -- Grad der Konsanguinitaet
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0109,    -- Erstgradig verwandt
									at0110,    -- Zweitgradig verwandt
									at0111,    -- Weiter entfernt verwandt
									at0112,    -- Unbekannt
									at0113]    -- Nicht dokumentiert
								}
							}
						}
					}
					ELEMENT[at0020] occurrences matches {0..1} matches {    -- Konsanguinitaetsdetail
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

