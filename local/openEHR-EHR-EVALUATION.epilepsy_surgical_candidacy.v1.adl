description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Bewertung der epilepsiechirurgischen Eignung und des weiteren praechirurgischen Vorgehens.">
			use = <"Zur strukturierten Dokumentation von Kandidatur, noch benoetigter Zusatzdiagnostik und naechsten Schritten im Board oder Fallkonferenzprozess.">
			misuse = <"Nicht als Operationsbericht oder als Ersatz fuer publizierte Prozedurartefakte verwenden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Evaluation of epilepsy-surgery candidacy and the remaining presurgical pathway.">
			use = <"Use for structured documentation of candidacy, additional workup needs, and next steps in conference or board review.">
			misuse = <"Do not use as an operative report or as a replacement for published procedure artefacts.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"f7efe54271b236028eaf4c3091f0c78b">
		["build_uid"] = <"ee3a2cb4-5b49-3cf9-a03e-afe0748fcc3a">
	>

definition
	EVALUATION[at0000] matches {    -- Epilepsiechirurgische Kandidatur
		data matches {
			ITEM_TREE[at0001] matches {    -- Kandidaturdaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Stadium der praechirurgischen Abklaerung
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- Nicht begonnen
									at0101,    -- Laufend
									at0102,    -- Abgeschlossen
									at0103]    -- Zurueckgestellt
								}
							}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Epilepsiechirurgischer Kandidat
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0110,    -- Kandidat
									at0111,    -- Potenzieller Kandidat
									at0112,    -- Kein Kandidat
									at0113]    -- Unbestimmt
								}
							}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Begruendung der Kandidatur
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Resektive Option erwogen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Neuromodulation erwogen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0015] occurrences matches {0..*} matches {    -- Zusaetzliche Abklaerung erforderlich
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0120,    -- Hochaufloesendes MRT
									at0121,    -- Verlaengertes Video-EEG
									at0122,    -- Funktionelle Bildgebung
									at0123,    -- Invasives EEG
									at0124,    -- Neuropsychologie
									at0125,    -- Genetische Neubewertung
									at0126]    -- Psychiatrische Bewertung
								}
							}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- In Fallkonferenz vorgestellt
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Datum der Fallkonferenz
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Geplanter naechster Schritt
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

