archetype (adl_version=1.4; uid=22a8b404-6107-4fbc-bfb1-ae55df55e556)
	openEHR-EHR-EVALUATION.epilepsy_safety_counselling.v1

concept
	[at0000]

language
	original_language = <[ISO_639-1::de]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"vEC team">
			>
		>
	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Dokumentation epilepsiespezifischer Sicherheitsaufklaerung und Risikoberatung.">
			use = <"Zur strukturierten Dokumentation, welche Sicherheitsaspekte mit Familie oder Patient besprochen wurden, inklusive SUDEP-Datum, Medium und Rueckfragen oder Entscheidungen.">
			misuse = <"Nicht als Ersatz fuer publizierte Health-Risk- oder allgemeine Aufklaerungsartefakte verwenden, wenn diese den Bedarf bereits vollstaendig abdecken.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Documentation of epilepsy-specific safety counselling and risk discussion.">
			use = <"Use for structured documentation of which epilepsy safety topics were discussed with the family or patient, including SUDEP date, counselling medium, and questions or decisions.">
			misuse = <"Do not use as a replacement for published health-risk or generic counselling artefacts when those fully cover the need.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"fd9121f12c419742ed994d6f0c920d13">
		["build_uid"] = <"67b6f3c0-a27c-3624-8642-010f62b152dc">
	>

definition
	EVALUATION[at0000] matches {    -- Epilepsiespezifische Sicherheitsberatung
		data matches {
			ITEM_TREE[at0001] matches {    -- Beratungsdaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- SUDEP besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Notfallplan geprueft
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Wassersicherheit besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Badeaufsicht besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Hoehen und Klettern besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Fahrrad- und Verkehrssicherheit besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- Schlafsicherheit besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Fahreignung besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Schulischer Notfallplan besprochen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0019] occurrences matches {0..1} matches {    -- Beratungszusammenfassung
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0020] occurrences matches {0..1} matches {    -- SUDEP-Beratungsdatum
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0021] occurrences matches {0..1} matches {    -- SUDEP-Beratungsmedium
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- Persoenlich
									at0101,    -- Schriftliches Material
									at0102,    -- Digitales Material
									at0103,    -- Telefon oder Video
									at0104,    -- Gemischt
									at0105]    -- Unbekannt
								}
							}
						}
					}
					ELEMENT[at0022] occurrences matches {0..1} matches {    -- SUDEP-Rueckfragen oder Entscheidungen
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

