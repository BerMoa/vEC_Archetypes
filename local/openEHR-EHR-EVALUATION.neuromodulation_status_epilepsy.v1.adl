archetype (adl_version=1.4; uid=4f5c504e-9841-41e2-a66d-5d9eefbe49d0)
	openEHR-EHR-EVALUATION.neuromodulation_status_epilepsy.v1

concept
	[at0000]

language
	original_language = <[ISO_639-1::de]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"vEC team">
			>
		>
	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Laengsschnittbewertung des neuromodulatorischen Therapiezustands bei Epilepsie.">
			use = <"Zur Dokumentation von Implantationsstatus, Therapieansprechen, Programmierereignissen und relevanten Geraeteproblemen.">
			misuse = <"Nicht als Ersatz fuer publizierte Prozedurereignisse oder Geraetedokumentation mit voller technischer Parametrisierung verwenden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Longitudinal evaluation of neuromodulation status in epilepsy care.">
			use = <"Use for implant status, therapy response, programming follow-up, and clinically relevant device issues.">
			misuse = <"Do not use as a replacement for published procedure events or fully technical device-programming records.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"022181c6f9b4533ad002b5176856189c">
		["build_uid"] = <"dd89f6e9-b924-33f0-9d16-78c4b22e435a">
	>

definition
	EVALUATION[at0000] matches {    -- Neuromodulationsstatus Epilepsie
		data matches {
			ITEM_TREE[at0001] matches {    -- Statusdaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Geraetetyp
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- Vagusnervstimulation
									at0101,    -- Responsive Neurostimulation
									at0102,    -- Tiefe Hirnstimulation
									at0103]    -- Andere
								}
							}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Implantationsstatus
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0110,    -- Geplant
									at0111,    -- Implantiert und aktiv
									at0112,    -- Implantiert und inaktiv
									at0113,    -- Explantiert
									at0114]    -- Kein Kandidat
								}
							}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Implantationsdatum
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Letztes Programmierdatum
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Therapieansprechen
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0120,    -- Anfallsfrei
									at0121,    -- Ausgepraegte Besserung
									at0122,    -- Teilweise Besserung
									at0123,    -- Kein Ansprechen
									at0124,    -- Verschlechterung
									at0125]    -- Unbekannt
								}
							}
						}
					}
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Stimulationsbezogene Nebenwirkungen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- Batterie- oder Hardwareproblem vorhanden
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- MRT-Konditionalitaet geprueft
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Zusammenfassung der Neuromodulation
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

