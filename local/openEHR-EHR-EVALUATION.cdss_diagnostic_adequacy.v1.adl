archetype (adl_version=1.4; uid=3bac59da-01c9-4b06-a661-e7fb4501641c)
	openEHR-EHR-EVALUATION.cdss_diagnostic_adequacy.v1

concept
	[at0000]

language
	original_language = <[ISO_639-1::de]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"vEC team">
			>
		>
	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"CDSS-Ampelausgabe zur diagnostischen Adaequanz pro Domaene.">
			use = <"Zur Dokumentation von Ampelstufe, Regelanzahl, Begruendung und aerztlicher Uebersteuerung. Diese Evaluation beschreibt klinisch kuratierten CDSS-Output und traegt keine NLP-Provenienz.">
			misuse = <"Nicht als alleinige klinische Entscheidungsgrundlage ohne aerztliche Bestaetigung verwenden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Traffic-light CDSS output for diagnostic adequacy per domain.">
			use = <"Use for adequacy level, rule counts, rationale, and physician override metadata. This evaluation represents curated CDSS output and does not carry NLP provenance by default.">
			misuse = <"Do not use as the sole basis for clinical decision making without physician confirmation.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"7148a4b936e1a73ce81a551b84eb9a11">
		["build_uid"] = <"a68b5ddb-e895-3c6f-bcba-9127046f01d4">
	>

definition
	EVALUATION[at0000] matches {    -- CDSS Diagnoseadaequanz
		data matches {
			ITEM_TREE[at0001] matches {    -- Bewertungsdaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Domaene
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- EEG
									at0101,    -- MRT
									at0102,    -- Genetik
									at0103]    -- Gesamt
								}
							}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Adaequanzstufe
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0104,    -- Gruen
									at0105,    -- Gelb
									at0106]    -- Rot
								}
							}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Regeln evaluiert
						value matches {
							DV_COUNT matches {*}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Regeln ausgeloest
						value matches {
							DV_COUNT matches {*}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Ausgeloeste Regel-IDs
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Adaequanzbegruendung
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- CDSS-Engine-Version
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Aerztliche Uebersteuerung
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Uebersteuerungsbegruendung
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0019] occurrences matches {0..1} matches {    -- Uebersteuerungszeitpunkt
						value matches {
							DV_DATE_TIME matches {*}
						}
					}
					ELEMENT[at0020] occurrences matches {0..1} matches {    -- CDSS-Safety-Gate bestanden
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
				}
			}
		}
	}

