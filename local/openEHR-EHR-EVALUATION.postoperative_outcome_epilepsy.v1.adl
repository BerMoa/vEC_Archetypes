archetype (adl_version=1.4; uid=a108ff21-6191-487a-b558-7a138fa6dbd3)
	openEHR-EHR-EVALUATION.postoperative_outcome_epilepsy.v1

concept
	[at0000]

language
	original_language = <[ISO_639-1::de]>
	translations = <
		["en"] = <
			language = <[ISO_639-1::en]>
			author = <
				["name"] = <"vEC team">
			>
		>
	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Laengsschnittbewertung des postoperativen Anfallsverlaufs und der klinischen Nachsorge nach epilepsiechirurgischen Eingriffen.">
			use = <"Zur Dokumentation von Outcome-Klassifikation, Komplikationen und geplanter Nachsorge nach Operation oder Ablation.">
			misuse = <"Nicht als Ersatz fuer den eigentlichen Operationsbericht oder das publizierte Prozedurartefakt verwenden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Longitudinal evaluation of postoperative seizure outcome and follow-up after epilepsy procedures.">
			use = <"Use for outcome classification, complications, and planned follow-up after surgery or ablation.">
			misuse = <"Do not use as a replacement for the operative report or the published procedure artefact.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"881559d9bec00977d7b345127c40c05c">
		["build_uid"] = <"b906d486-303b-3f6a-be80-7de155a4c5da">
	>

definition
	EVALUATION[at0000] matches {    -- Postoperatives Outcome Epilepsie
		data matches {
			ITEM_TREE[at0001] matches {    -- Outcomedaten
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Typ des epilepsiechirurgischen Eingriffs
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0100,    -- Laesionektomie
									at0101,    -- Lobektomie
									at0102,    -- Hemisphaerotomie
									at0103,    -- Kallosotomie
									at0104,    -- Laserablation
									at0105,    -- Neuromodulationsimplantation
									at0106]    -- Andere
								}
							}
						}
					}
					ELEMENT[at0011] occurrences matches {0..1} matches {    -- Operationsdatum
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Outcome-Klassifikationssystem
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0110,    -- Engel
									at0111,    -- ILAE postoperativ
									at0112]    -- Andere
								}
							}
						}
					}
					ELEMENT[at0013] occurrences matches {0..1} matches {    -- Outcome-Klassifikationswert
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0120,    -- Engel I
									at0121,    -- Engel II
									at0122,    -- Engel III
									at0123,    -- Engel IV
									at0124,    -- ILAE 1
									at0125,    -- ILAE 2
									at0126,    -- ILAE 3
									at0127,    -- ILAE 4
									at0128,    -- ILAE 5
									at0129,    -- ILAE 6
									at0130,    -- Nicht zutreffend
									at0131]    -- Unbekannt
								}
							}
						}
					}
					ELEMENT[at0014] occurrences matches {0..1} matches {    -- Zusammenfassung des Anfallsoutcomes
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Neurologische Komplikation vorhanden
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0016] occurrences matches {0..1} matches {    -- Zusammenfassung postoperativer Komplikationen
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- ASM-Reduktion erwogen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0018] occurrences matches {0..1} matches {    -- Reoperation erwogen
						value matches {
							DV_BOOLEAN matches {*}
						}
					}
					ELEMENT[at0019] occurrences matches {0..1} matches {    -- Postoperativer Nachsorgeplan
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}

