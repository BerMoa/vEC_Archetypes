	>

description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Strukturierte Beobachtung fortgeschrittener Lokalisationsdiagnostik im epilepsiechirurgischen Kontext.">
			use = <"Eine Instanz pro FDG-PET-, SPECT-, MEG- oder MSI-, fMRT- oder EEG-Source-Imaging-Studie.">
			misuse = <"Nicht als Ersatz fuer publizierte generische Bildgebungs- oder Laborartefakte verwenden; diese sollen im Template gemeinsam genutzt werden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Structured observation of advanced localization studies in presurgical epilepsy care.">
			use = <"Use one instance per FDG PET, SPECT, MEG or MSI, functional MRI, or EEG source-imaging study.">
			misuse = <"Do not use as a replacement for published generic imaging or laboratory artefacts; pair them in the template.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"84c8f2e029c05bce1e5b8575d6d566e5">
		["build_uid"] = <"0d831ad0-4e26-3c0f-8252-b3de2bc96100">
	>

definition
	OBSERVATION[at0000] matches {    -- Fortgeschrittene Lokalisationsdiagnostik Epilepsie
		data matches {
			HISTORY[at0001] matches {    -- Verlauf
				events cardinality matches {1..1; unordered} matches {
					POINT_EVENT[at0002] matches {    -- Lokalisationsereignis
						data matches {
							ITEM_TREE[at0003] matches {    -- Lokalisationsdaten
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Lokalisationsmodalitaet
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0100,    -- FDG-PET interiktal
													at0101,    -- FDG-PET iktal
													at0102,    -- SPECT iktal
													at0103,    -- SPECT interiktal
													at0104,    -- SISCOM
													at0105,    -- MEG oder MSI
													at0106,    -- fMRT Sprache
													at0107,    -- fMRT Motorik
													at0108,    -- EEG-Source-Imaging
													at0109]    -- Andere
												}
											}
										}
									}
									ELEMENT[at0011] occurrences matches {0..1} matches {    -- Studiendatum
										value matches {
											DV_DATE matches {*}
										}
									}
									ELEMENT[at0012] occurrences matches {0..1} matches {    -- Durchfuehrende Institution
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0013] occurrences matches {0..1} matches {    -- Zielstellung
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0110,    -- Anfallslokalisation
													at0111,    -- Sprachlateralisation
													at0112,    -- Motorische Kartierung
													at0113,    -- Netzwerkdefinition
													at0114]    -- Operationsplanung
												}
											}
										}
									}
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- Lateralisierung des Ergebnisses
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0120,    -- Links
													at0121,    -- Rechts
													at0122,    -- Beidseitig
													at0123,    -- Mittellinie
													at0124,    -- Nicht lateralisiert
													at0125]    -- Nicht zutreffend
												}
											}
										}
									}
									ELEMENT[at0015] occurrences matches {0..*} matches {    -- Lokalisation des Ergebnisses
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0130,    -- Frontal
													at0131,    -- Temporal
													at0132,    -- Parietal
													at0133,    -- Okzipital
													at0134,    -- Insulaer
													at0135,    -- Cingulaer
													at0136,    -- Multilobaer
													at0137,    -- Hemisphaerisch
													at0138,    -- Diffus
													at0139]    -- Nicht lokalisierend
												}
											}
										}
									}
									ELEMENT[at0016] occurrences matches {0..1} matches {    -- Konkordanz mit Skalp-EEG
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0140,    -- Konkordant
													at0141,    -- Teilweise konkordant
													at0142,    -- Diskordant
													at0143,    -- Unbestimmt
													at0144]    -- Nicht beurteilt
												}
											}
										}
									}
									ELEMENT[at0017] occurrences matches {0..1} matches {    -- Konkordanz mit MRT
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0140,    -- Konkordant
													at0141,    -- Teilweise konkordant
													at0142,    -- Diskordant
													at0143,    -- Unbestimmt
													at0144]    -- Nicht beurteilt
												}
											}
										}
									}
									ELEMENT[at0018] occurrences matches {0..1} matches {    -- Konkordanz mit Semiologie
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0140,    -- Konkordant
													at0141,    -- Teilweise konkordant
													at0142,    -- Diskordant
													at0143,    -- Unbestimmt
													at0144]    -- Nicht beurteilt
												}
											}
										}
									}
									ELEMENT[at0019] occurrences matches {0..1} matches {    -- Chirurgische Verwertbarkeit
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0150,    -- Lokalisiert und verwertbar
													at0151,    -- Unterstuetzend, aber nicht allein lokalisierend
													at0152,    -- Nicht beitragend
													at0153]    -- Diskordant zur Operationsplanung
												}
											}
										}
									}
									ELEMENT[at0020] occurrences matches {0..1} matches {    -- Zusammenfassung der Lokalisationsstudie
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0900] occurrences matches {0..1} matches {    -- Provenienzslot
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.vec_extraction_provenance\.v[0-9]+/}
									}
								}
							}
						}
					}
				}
			}
		}
	}

