description
	original_author = <
		["date"] = <"2026-03-26">
		["name"] = <"vEC - Virtual Epilepsy Clinic">
		["organisation"] = <"Charite Universitaetsmedizin Berlin">
	>
	lifecycle_state = <"in_development">
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Strukturierte Beratung zu Transition, Selbstmanagement und reproduktiver Gesundheit bei jugendlichen Epilepsiepatienten.">
			use = <"Zur Dokumentation von Uebergang in die Erwachsenenversorgung, Selbststaendigkeit, Kontrazeption, teratogenem Risiko und genetischer Beratung.">
			misuse = <"Nicht als Ersatz fuer allgemeine gynäkologische oder reproduktionsmedizinische Fachdokumentation verwenden.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"Structured counselling about transition, self-management, and reproductive health in adolescents with epilepsy.">
			use = <"Use for transition-to-adult-care planning, autonomy, contraception, teratogenic risk, and genetic counselling discussion.">
			misuse = <"Do not use as a replacement for general gynecology or reproductive-medicine documentation.">
		>
	>
	other_details = <
		["MD5-CAM-1.0.1"] = <"d6a442a7e0310f3165d44e5f0b752833">
