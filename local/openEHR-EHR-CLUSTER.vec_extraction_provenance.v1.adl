					description = <"Outpatient clinical letter.">
				>
				["at0111"] = <
					text = <"EEG report">
					description = <"Report of an EEG study.">
				>
				["at0112"] = <
					text = <"MRI report">
					description = <"Report of an MRI study.">
				>
				["at0113"] = <
					text = <"Genetics report">
					description = <"Genetic findings report.">
				>
				["at0114"] = <
					text = <"Discharge summary">
					description = <"Discharge summary or discharge letter.">
				>
				["at0115"] = <
					text = <"Referral letter">
					description = <"Referral letter.">
				>
				["at0116"] = <
					text = <"Caregiver intake form">
					description = <"Caregiver intake or questionnaire document.">
				>
			>
		>
	>
